# Application
APP_NAME=Oil Prediction Screen API
DEBUG=true
VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/oil_prediction

# AI Configuration
AI_PROVIDER=openai
AI_MOCK_ENABLED=false
APP_AI_KEY=your-api-key-here
APP_AI_BASE_URL=https://api.openai.com/v1

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Admin User
ADMIN_USER_ID=admin-001
ADMIN_USER_EMAIL=admin@example.com

# OIDC Configuration (if using OAuth)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile

# Allowed Domains
ALLOWED_DOMAINS=*

# Frontend URL
FRONTEND_URL=http://localhost:5173
